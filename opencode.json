{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": ["php", "artisan", "boost:mcp"]
        },
        "devtools-browser": {
            "type": "local",
            "enabled": true,
            "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
        }
    },
    "permission": {
        "devtools-browser_*": "allow"
    }
}
