{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
	   "devtools-browser": {
     	   "type": "local",
           "command": ["npx", "-y", "YOUR_MCP_PACKAGE_NAME"],
           "enabled": true
         },
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}
